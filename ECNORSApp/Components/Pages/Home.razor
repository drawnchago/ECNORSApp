@page "/"
@using ECNORSAppData.Data.Config
@using ECNORSAppData.Data.Models
@using ECNORSAppData.Data.DTO
@using ECNORSApp.Services
@using System.Text.Json.Serialization;
@inject CloseLoadApi CloseLoadApi
@inject IConnectionSelector ConnectionSelector
@inject SelectedConnectionState ConnState
@inject ECNORSApp.Services.IToastService ToastService
@inject ILogger<Home> Logger
@inject ECNORSApp.Services.IFileLoggerService FileLogger

@* @inject IJSRuntime JS *@

    <h4>Selecciona la estación </h4>


@* <button class="btn btn-info" @onclick="ShowLogPath">
    Ver ruta del log
</button>

<button class="btn btn-success" @onclick="WriteTestLog">
    Escribir prueba
</button> *@

<button class="btn btn-warning" @onclick="ExportLog">
    Exportar log a Descargas
</button>


        <div class="d-flex align-items-center gap-2 mt-2">
            <select class="form-select" style="max-width:260px" @bind="selectedName" disabled="@isBusy">
                <option value="">-- Selecciona --</option>
                @foreach (var c in connections)
                {
                    <option value="@c.name">@c.name</option>
                }
            </select>
            
            @if (!isConnected)
            {
                    <button class="btn btn-primary"
                            @onclick="ConnectAsync"
                            disabled="@(!CanConnect || isBusy || isConnected)">
                        @if (isBusy)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>Conectando...</span>
                        }else{
                           <span>Conectar</span>
                        }
                    </button>
            }

            @if (isConnected)
            {
                <button class="btn btn-danger"
                    @onclick="CancelConnection">
                            Desconectar
                </button>
            }
        </div>



@if (isConnected)
{
    <hr class="my-3" />

    <h5>Dispensarios</h5>

    @if (isLoadingDispensarios)
    {
        <div>Cargando dispensarios...</div>
    }
    else if (!string.IsNullOrWhiteSpace(errorDispensarios))
    {
        <div class="text-danger">@errorDispensarios</div>
    }
    else
    {

        <select class="form-select"
                value="@selectedDispensarioId"
                @onchange="async e => await OnDispensaryChanged(e)">
            <option value="">-- Selecciona dispensario --</option>
            @foreach (var d in dispensarios)
            {
                <option value="@d.DispensaryId">@d.DisplayName</option>
            }
        </select>

    }
    @if (selectedDispensarioId.HasValue)
    {
        <hr class="my-3" />

        @if (isLoadingTables)
        {
            <div>Cargando Bitácora y Transacciones...</div>
        }
        else if (!string.IsNullOrWhiteSpace(errorTables))
        {
            <div class="text-danger">@errorTables</div>
        }
        else
        {
            <h5>Bitácora (Top 7)</h5>
            <div class="cardish mt-3">
                <div class="table-title header-bitacora">
                    <h5 class="m-0">Bitácora</h5>
                    <span class="badge-soft">Top 7 • últimas 24h</span>
                </div>
                <div class="table-shell">
                    <table class="nice-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th class="num">Totalizador</th>
                                <th class="num">Tot.Original</th>
                                <th class="num">Tot.Or.Final</th>
                                <th class="num">Programado</th>
                                <th class="num">Vendido</th>
                                <th class="num">Vol. Vendido</th>
                                <th class="num">Precio</th>
                                <th>Cerrada</th>
                                <th>Observaciones</th>
                                <th>Fecha</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (binnacle.Count == 0)
                            {
                                <tr>
                                    <td colspan="8" class="muted">Sin registros para este dispensario.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var r in binnacle)
                                {
                                   <tr style="cursor:pointer" title="Click para detalle" @onclick="() => OpenBinnacleModal(r)">
                                        <td>@r.id</td>
                                        <td class="num">@r.Totalizator</td>
                                        <td class="num">@r.OriginTotalizator</td>
                                        <td class="num">@r.EndTotalizator</td>
                                        <td class="num">@Format2(r.Scheduled)</td>
                                        <td class="num">@Format2(r.Sold)</td>
                                        <td class="num">@Format2(r.SoldVolume)</td>
                                        <td class="num">@Format2(r.UnitPrice)</td>
                                        <td>
                                            @if (r.Closed == true)
                                            {
                                                <span class="pill ok">Sí</span>
                                            }
                                            else if (r.Closed == false)
                                            {
                                                <span class="pill no">No</span>
                                            }
                                            else
                                            {
                                                <span class="pill muted">N/A</span>
                                            }
                                        </td>
                                        <td>@r.Observations</td>
                                        <td>@(r.Date?.ToString("yyyy-MM-dd HH:mm"))</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>


            <h5 class="mt-4">Transacciones (Top 7)</h5>
            <div class="cardish mt-4 card-comfy">
                <div class="table-title header-transacciones title-comfy">
                    <h5 class="m-0">Transacciones</h5>
                    <span class="badge-soft">Top 7 • últimas 24h</span>
                </div>

                <div class="table-shell table-shell-bottom shell-comfy">
                 <table class="nice-table table-comfy">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Fecha</th>
                                <th class="num">Volumen</th>
                                <th class="num">Importe</th>
                                <th class="num">Precio</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (transactions.Count == 0)
                            {
                                <tr>
                                    <td colspan="5" class="muted">Sin registros para este dispensario.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var r in transactions)
                                {
                                    <tr>
                                        <td>@r.id</td>
                                        <td>@(r.Date?.ToString("yyyy-MM-dd HH:mm"))</td>
                                        <td class="num">@Format2(r.Volume)</td>
                                        <td class="num">@Format2(r.Amount)</td>
                                        <td class="num">@Format2(r.UnitPrice)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        }
    }

    @if (showBinnacleModal && selectedBinnacle is not null)
    {
        <div class="modal-backdrop blue-backdrop" @onclick="CloseBinnacleModal"></div>

        <div class="modal d-block" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered"
                 @onclick:stopPropagation="true">
                <div class="modal-content modal-blue">

                    <!-- HEADER -->
                    <div class="modal-header modal-blue-header">
                        <h5 class="modal-title">
                            Detalle (Secuencia @selectedBinnacle.id)
                        </h5>
                        <button type="button" class="btn-close" @onclick="CloseBinnacleModal"></button>
                    </div>

                    <!-- BODY -->
                    <div class="modal-body">

                        <div class="col-12 col-md-4 text-center mb-2">
                            <label class="form-label fw-bold text-primary"># Secuencia</label>
                            <input class="form-control text-center fw-bold fs-4 input-blue-readonly"
                                   value="@(selectedBinnacle?.id.ToString() ?? "")"
                                   readonly />
                        </div>

                        <div class="row g-2 mb-2">
                            <div class="col-6">
                                <label class="form-label fw-bold">Dispensario</label>
                                <input class="form-control input-blue-readonly fw-bold"
                                       value="@selectedBinnacle?.DispensaryId"
                                       readonly />
                            </div>

                            <div class="col-6">
                                <label class="form-label fw-bold">Manguera</label>
                                <input class="form-control input-blue-readonly"
                                       value="@selectedBinnacle?.HoseId"
                                       readonly />
                            </div>
                        </div>

                        <div class="col-12 col-md-4 mb-3">
                            <label class="form-label fw-bold">Producto</label>
                            <input class="form-control fw-bold text-white text-center @(selectedBinnacle?.ProductId switch
                               {
                                   1 => "bg-red",
                                   2 => "bg-primary",
                                   3 => "bg-dark",
                                   _ => ""
                               })"
                               value="@(
                                    selectedBinnacle?.ProductId == 1 ? "SUPREME +" :
                                   selectedBinnacle?.ProductId == 2 ? "EXTRA" :
                                   selectedBinnacle?.ProductId == 3 ? "DIESEL" :
                                   selectedBinnacle?.ProductId?.ToString() ?? "")"
                               readonly />
                        </div>
                        <div class="section-separator">
                            <span>Bitácora</span>
                        </div>
                        <div class="row g-2 mb-2">
                            <div class="col-6">
                                <label class="form-label fw-bold">Vendido (Neto)</label>
                                <input class="form-control input-blue-readonly"
                                       value="@selectedBinnacle?.Sold"
                                       readonly />
                            </div>

                            <div class="col-6">
                                <label class="form-label fw-bold">V. Vendido (Bruto)</label>
                                <input class="form-control input-blue-readonly"
                                       value="@selectedBinnacle?.SoldVolume"
                                       readonly />
                            </div>
                        </div>
                        <div class="section-separator">
                            <span>Corrección</span>
                        </div>
                        <div class="row g-2 mb-2">
                            <div class="col-12">
                                <label class="form-label fw-bold">Totalizador</label>
                                <input class="form-control input-blue-readonly"
                                       type="number"
                                       step="0.001"
                                       value="@selectedBinnacle?.Totalizator"
                                       readonly />
                            </div>
                        </div>

                        <div class="row g-2 mb-2">
                            <div class="col-6">
                                <label class="form-label fw-bold">V. Bruto (GROSS)</label>
                                <input class="form-control input-blue"
                                       type="number"
                                       @bind="inputGross" />
                            </div>

                            <div class="col-6">
                                <label class="form-label fw-bold">V. Neto</label>
                                <input class="form-control input-blue"
                                       type="number"
                                       @bind="inputNeto" />
                            </div>
                        </div>

                        <div class="col-12 mb-2">
                            <label class="form-label fw-bold">Temperatura</label>
                            <input class="form-control input-blue"
                                   type="number"
                                   @bind="inputTemperatura" />
                        </div>

                        @if (!string.IsNullOrWhiteSpace(errorModal))
                        {
                            <div class="text-danger fw-bold mt-2">@errorModal</div>
                        }

                    </div>

                    <!-- FOOTER -->
                    <div class="modal-footer modal-blue-footer">
                        <button class="btn btn-outline-primary" @onclick="CloseBinnacleModal">
                            Cerrar
                        </button>

                        <button class="btn btn-success" @onclick="SaveModal" disabled="@isSavingModal">
                            @(isSavingModal ? "Guardando..." : "Guardar")
                        </button>
                    </div>

                </div>
            </div>
        </div>
    }



    @code {
    private decimal? inputTotalizador;
    private decimal inputGross;
    private decimal inputNeto;
    private decimal inputTemperatura;

    private List<ConnItem> connections = new();
    private string selectedName = "";

    private bool isBusy = false;              
    private bool isConnected = false;         
    private string status = "";

    private bool isLoadingDispensarios = false;
    private string? errorDispensarios;

    private List<DispensaryDto> dispensarios = new(); 
    private int? selectedDispensarioId;

    private bool CanConnect => !string.IsNullOrWhiteSpace(selectedName);
    private bool HasSelectedDispensario => selectedDispensarioId.HasValue;
    private bool isLoadingTables = false;
    private string? errorTables;
    private List<TransactionDto> transactions = new();
    private List<BinnacleDto> binnacle = new();
    private static string Format2(double? v) => v.HasValue ? v.Value.ToString("N2") : "-";

    // ===== Modal state =====
    private bool showBinnacleModal = false;
    private bool isSavingModal = false;
    private string? errorModal;

    private BinnacleDto? selectedBinnacle;

    private TransactionDto? selectedTransaction;
    private double? editTrxVolume;
    private double? editTrxAmount;
    private double? editTrxUnitPrice;


    protected override async Task OnInitializedAsync()
    {
        connections = ConnectionSelector.GetConnections().ToList();
        selectedName = ConnState.GetSelectedName() ?? "";
        isConnected = false;
    }

private async Task ConnectAsync()
{
    if (!CanConnect || isConnected) return;

    isBusy = true;
    errorDispensarios = null;

    dispensarios.Clear();
    selectedDispensarioId = null;
    isConnected = false;

    try
    {
        ConnState.SetSelectedName(selectedName);
        var result = await CloseLoadApi.GetDbInfoAsync(selectedName);

        if (result is null || !result.Success)
        {
            ToastService.ShowError(result?.Message ?? "No se recibió información de conexión.");
            return;
        }

        await LoadDispensariosAsync();

        isConnected = true;

        await FileLogger.InfoAsync($"Conectado a {selectedName}");
        ToastService.ShowSuccess(result.Message ?? "Conexión exitosa");
    }
    catch (Exception ex)
    {
        isConnected = false;
        await FileLogger.ErrorAsync("ConnectAsync=>" + ex.Message);
        ToastService.ShowError(ex.Message, "Error al establecer conexion");
    }
}


private async Task LoadDispensariosAsync()
{
    isLoadingDispensarios = true;
    errorDispensarios = null;

    try
    {
        // selectedName ya es tu station seleccionada
        var station = selectedName;

        if (string.IsNullOrWhiteSpace(station))
        {
            errorDispensarios = "Seleccione una estación.";
            dispensarios.Clear();
            return;
        }

        // Llama al API mandando station
        var list = await CloseLoadApi.GetDispensariosAsync(station);

        // Guarda en el campo (no en una variable local)
        dispensarios = list.ToList();
    }
    catch (Exception ex)
    {
        errorDispensarios = ex.Message;
        await FileLogger.ErrorAsync("LoadDispensariosAsync => " + ex);
        ToastService.ShowError(ex.Message, "Error al obtener los dispensarios");
    }
    finally
    {
        isLoadingDispensarios = false;
        StateHasChanged();
    }
}



    private void CancelConnection()
    {
        isConnected = false;
        status = "Desconectada 🔴";

        dispensarios.Clear();
        selectedDispensarioId = null;
        errorDispensarios = null;

        ConnState.SetSelectedName("");
        selectedName = "";
        isBusy=false;
    }

    private async Task OnDispensaryChanged(ChangeEventArgs e)
    {
        if (e?.Value is null || string.IsNullOrWhiteSpace(e.Value.ToString()))
        {
            selectedDispensarioId = null;
            transactions.Clear();
            binnacle.Clear();
            return;
        }

        selectedDispensarioId = int.Parse(e.Value.ToString()!);

        isLoadingTables = true;
        errorTables = null;
        transactions.Clear();
        binnacle.Clear();
        StateHasChanged();

        try
        {
            var dispId = selectedDispensarioId.Value;

            await FileLogger.InfoAsync("Dispensario seleccionado =>" + dispId);

            var bTask = CloseLoadApi.GetBinnacleTopAsync(selectedName, dispId);
            var tTask = CloseLoadApi.GetTransactionsTopAsync(selectedName, dispId);

            await Task.WhenAll(bTask, tTask);

            binnacle = (await bTask).ToList();
            transactions = (await tTask).ToList();
        }
        catch (Exception ex)
        {
            await FileLogger.ErrorAsync("OnDispensaryChanged=>" + ex.Message);
            ToastService.ShowError("Error al obtener la bitacora y/o transacciones");
        }
        finally
        {
            isLoadingTables = false;
            StateHasChanged();
        }
    }


    private async Task OpenBinnacleModal(BinnacleDto row)
    {
        selectedBinnacle = row;
        errorModal = null;

        showBinnacleModal = true;
        StateHasChanged();

        try
        {
            selectedTransaction =  await CloseLoadApi.GetTransactionBySequenceAsync(selectedName, row.id);


            if (selectedTransaction is not null)
            {
                editTrxVolume = selectedTransaction.Volume;
                editTrxAmount = selectedTransaction.Amount;
                editTrxUnitPrice = selectedTransaction.UnitPrice;
            }
            else
            {
                errorModal = "No se encontró transacción para esta secuencia.";
            }
        }
        catch (Exception ex)
        {
            errorModal = ex.ToString();
        }

        StateHasChanged();
    }


    private void CloseBinnacleModal()
    {
        showBinnacleModal = false;
        selectedBinnacle = null;
        errorModal = null;
    }

    private async Task SaveModal()
    {
        isSavingModal = true;

        if (inputTotalizador == 0 || inputGross <= 0 || inputNeto <= 0 || inputTemperatura == 0)
        {
            ToastService.ShowError("Debe capturar Totalizador, Bruto, Neto y Temperatura.");
            isSavingModal = false; 
            return;
        }

        try
        {
            await CloseLoadApi.CloseManualAsync(
                station: selectedName,
                secuenciaBuscar: selectedBinnacle!.id,
                totalizador: inputTotalizador ?? 0m,
                volumenGross: inputGross,
                volumenNetoCt: inputNeto,
                temperatura: inputTemperatura);

            ToastService.ShowSuccess("La carga fue cerrada correctamente.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message, "No se pudo cerrar la carga");
        }
        finally
        {
            isSavingModal = false;
            StateHasChanged();
        }
    }

    private async Task ShowLogPath()
{
    var path = await FileLogger.GetLogFilePathAsync();
    ToastService.ShowInfo(path, "Ruta real del log");
}

private async Task WriteTestLog()
{
    await FileLogger.InfoAsync("Prueba: el logger está funcionando ✅");
    ToastService.ShowSuccess("Se escribió una línea al log");
}
    private async Task ExportLog()
    {
        await FileLogger.ExportToDownloadsAsync();
        ToastService.ShowSuccess("Log copiado a Descargas");
    }

}
}
