@page "/"
@using ECNORSAppData.Data.Config
@using ECNORSAppData.Data.DTO
@using ECNORSApp.Services
@using System.Globalization
@inject CloseLoadApi CloseLoadApi
@inject IConnectionSelector ConnectionSelector
@inject SelectedConnectionState ConnState
@inject ECNORSApp.Services.IToastService ToastService
@inject ECNORSApp.Services.IFileLoggerService FileLogger

@* <div class="d-flex justify-content-end">
    <button class="btn btn-warning" @onclick="ExportLog" disabled="@isBusy">Exportar Log</button>
</div> *@

<h4>Estación</h4>
<div class="d-flex align-items-center gap-2 mt-2">
    <select class="form-select" style="max-width:260px" @bind="selectedName" disabled="@(isBusy || isConnected)">
        <option value="">-- Selecciona la estación --</option>
        @foreach (var c in connections)
        {
            <option value="@c.name">@c.name</option>
        }
    </select>

    @if (!isConnected)
    {
        <button class="btn btn-primary" @onclick="ConnectAsync" disabled="@(!CanConnect || isBusy)">
            @if (isBusy)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                <span>Conectando...</span>
            }
            else
            {
                <span>Conectar</span>
            }
        </button>
    }

    @if (isConnected)
    {
        <button class="btn btn-danger" @onclick="Disconnect">
            Desconectar
        </button>
    }
</div>

@if (isConnected)
{
    <hr class="my-3" />

    <h5>Dispensarios</h5>

    @if (isLoadingDispensaries)
    {
        <div>Cargando dispensarios...</div>
    }
    else if (!string.IsNullOrWhiteSpace(dispensariesError))
    {
        <div class="text-danger">@dispensariesError</div>
    }
    else
    {
        <select class="form-select" value="@selectedDispensaryId" @onchange="OnDispensaryChangedAsync">
            <option value="">-- Selecciona dispensario --</option>
            @foreach (var d in dispensaries)
            {
                <option value="@d.DispensaryId">@d.DisplayName</option>
            }
        </select>
    }

    @if (selectedDispensaryId.HasValue)
    {
        <hr class="my-3" />

        <div class="d-flex align-items-end gap-2 flex-wrap mb-3">
            <div>
                <h5>Selecciona el dia</h5>
                <input type="date"class="form-control"style="width: 380px;"@bind-value="selectedDay"@bind-value:format="yyyy-MM-dd"disabled="@isLoadingTables" />
            </div>
        </div>

        <button class="btn btn-outline-primary"style="width: 380px; margin-bottom:5%;"@onclick="ReloadByDayAsync"disabled="@isLoadingTables"> Buscar </button>

        @if (isLoadingTables)
        {
            <div>Cargando Bitácora y Transacciones...</div>
        }
        else if (!string.IsNullOrWhiteSpace(tablesError))
        {
            <div class="text-danger">@tablesError</div>
        }
        else
        {
            <h5>Reportes</h5>
            <div class="cardish mt-3">
                <div class="table-title header-bitacora">
                    <h5 class="m-0">Bitácora</h5>
                    <span class="badge-soft">Top 20 • día seleccionado</span>
                </div>

                <div class="table-shell">
                    <table class="nice-table">
                        <thead>
                            <tr>
                                <th>Secuencia</th>
                                <th class="num">Totalizador</th>
                                <th class="num">Tot.Original</th>
                                <th class="num">Tot.Or.Final</th>
                                <th class="num">Programado</th>
                                <th class="num">Vendido</th>
                                <th class="num">Vol. Vendido</th>
                                <th class="num">Precio</th>
                                <th>Cerrada</th>
                                <th>Observaciones</th>
                                <th>Fecha</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (binnacle.Count == 0)
                            {
                                <tr>
                                    <td colspan="11" class="muted">Sin registros para este dispensario en ese día.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var r in binnacle)
                                {
                                    <tr style="cursor:pointer" title="Click para detalle" @onclick="() => OpenBinnacleModalAsync(r)">
                                        <td>@r.id</td>
                                        <td class="num">@r.Totalizator</td>
                                        <td class="num">@r.OriginTotalizator</td>
                                        <td class="num">@r.EndTotalizator</td>
                                        <td class="num">@Format2(r.Scheduled)</td>
                                        <td class="num">@Format2(r.Sold)</td>
                                        <td class="num">@Format2(r.SoldVolume)</td>
                                        <td class="num">@Format2(r.UnitPrice)</td>
                                        <td>
                                            @if (r.Closed == true)
                                            {
                                                <span class="pill ok">Sí</span>
                                            }
                                            else if (r.Closed == false)
                                            {
                                                <span class="pill no">No</span>
                                            }
                                            else
                                            {
                                                <span class="pill muted">N/A</span>
                                            }
                                        </td>
                                        <td>@r.Observations</td>
                                        <td>@(r.Date?.ToString("yyyy-MM-dd HH:mm"))</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="cardish mt-4 card-comfy">
                <div class="table-title header-transacciones title-comfy">
                    <h5 class="m-0">Transacciones</h5>
                    <span class="badge-soft">Top 7 • últimas 24h</span>
                </div>

                <div class="table-shell table-shell-bottom shell-comfy">
                    <table class="nice-table table-comfy">
                        <thead>
                            <tr>
                                <th>Transaccion</th>
                                <th>Secuencia</th>
                                <th class="num">Volumen</th>
                                <th class="num">Importe</th>
                                <th class="num">Precio</th>
                                <th class="num">Totalizador F.</th>
                                <th>Fecha</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (transactions.Count == 0)
                            {
                                <tr>
                                    <td colspan="7" class="muted">Sin registros para este dispensario.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var r in transactions)
                                {
                                    <tr style="cursor:pointer" title="Click para detalle" @onclick="() => OpenTransactionModal(r)">
                                        <td>@r.TransactionId</td>
                                        <td>@r.id</td>
                                        <td class="num">@Format2(r.Volume)</td>
                                        <td class="num">@Format2(r.Amount)</td>
                                        <td class="num">@Format2(r.UnitPrice)</td>
                                        <td>@r.strTotalizadorFinal</td>
                                        <td>@(r.Date?.ToString("yyyy-MM-dd HH:mm"))</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
}

@* ========= MODALES (IGUAL QUE YA LOS TENÍAS) ========= *@
@if (showBinnacleModal)
{
    <div class="modal-backdrop blue-backdrop" @onclick="() => CloseModalAsync(true)"></div>

    <div class="modal d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">
            <div class="modal-content modal-blue">
                <div class="modal-header modal-blue-header">
                    <h5 class="modal-title">Detalle (#Sec. @(selectedBinnacle?.id.ToString() ?? "-"))</h5>
                    <button type="button" class="btn-close" @onclick="() => CloseModalAsync(true)"></button>
                </div>

                <div class="modal-body">
                    <MudStack Spacing="2" Style="margin-bottom:5%;">
                        <MudPaper Elevation="6" Class="@($"bitacora-acordeon {(_expandSequence ? "pa-4" : "pa-0")}")">
                            <MudButton OnClick="OnExpandCollapse3Click" FullWidth="true" Class="d-flex justify-content-center align-items-center">
                                <span class="fw-bold text-primary"># Secuencia</span>
                            </MudButton>
                            <MudDivider />
                            <MudCollapse Expanded="_expandSequence">
                                <div class="col-12 col-md-12 text-center mb-2">
                                    <input class="form-control text-center fw-bold fs-4 input-blue-readonly"
                                           value="@(selectedBinnacle?.id.ToString() ?? "")"
                                           readonly />
                                </div>
                            </MudCollapse>
                        </MudPaper>
                    </MudStack>

                    <MudStack Spacing="2" Style="margin-bottom:5%;">
                        <MudPaper Elevation="6" Class="@($"bitacora-acordeon {(_expandBinnacle ? "pa-4" : "pa-0")}")">
                            <MudButton OnClick="OnExpandCollapseClick" FullWidth="true" Class="d-flex justify-content-center align-items-center">
                                <span class="fw-bold text-primary">Bitacora</span>
                            </MudButton>
                            <MudDivider />
                            <MudCollapse Expanded="_expandBinnacle">
                                <div class="row g-2 mb-2">
                                    <div class="col-6">
                                        <label class="form-label fw-bold">Dispensario</label>
                                        <input class="form-control input-blue-readonly fw-bold" value="@selectedBinnacle?.DispensaryId" readonly disabled />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label fw-bold">Manguera</label>
                                        <input class="form-control input-blue-readonly" value="@selectedBinnacle?.HoseId" readonly disabled />
                                    </div>
                                </div>

                                <div class="col-12 col-md-12 mb-3">
                                    <label class="form-label fw-bold">Producto</label>
                                    <input class="form-control fw-bold text-white text-center @(selectedBinnacle?.ProductId switch
                                           {
                                               1 => "bg-red",
                                               2 => "bg-primary",
                                               3 => "bg-dark",
                                               _ => ""
                                           })"
                                           value="@(
                                           selectedBinnacle?.ProductId == 1 ? "SUPREME +" :
                                           selectedBinnacle?.ProductId == 2 ? "EXTRA" :
                                           selectedBinnacle?.ProductId == 3 ? "DIESEL" :
                                           selectedBinnacle?.ProductId?.ToString() ?? "")"
                                           readonly />
                                </div>

                                <div class="row g-2 mb-2">
                                    <div class="col-6">
                                        <label class="form-label fw-bold">Programado</label>
                                        <input class="form-control input-blue-readonly" value="@Format2(selectedBinnacle?.Scheduled)" readonly disabled />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label fw-bold">Vendido</label>
                                        <input class="form-control input-blue-readonly" value="@Format2(selectedBinnacle?.Sold)" readonly disabled />
                                    </div>
                                </div>

                                <div class="row g-2 mb-2">
                                    <div class="col-6">
                                        <label class="form-label fw-bold">Volumen vendido</label>
                                        <input class="form-control input-blue-readonly" value="@Format2(selectedBinnacle?.SoldVolume)" readonly disabled />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label fw-bold">Precio unitario</label>
                                        <input class="form-control input-blue-readonly" value="@Format2(selectedBinnacle?.UnitPrice)" readonly disabled />
                                    </div>
                                </div>
                            </MudCollapse>
                        </MudPaper>
                    </MudStack>

                    <MudStack Spacing="5">
                        <MudPaper Elevation="6" Class="@($"bitacora-acordeon {(_expandCloseLoad ? "pa-4" : "pa-0")}")">
                            <MudButton OnClick="OnExpandCollapse2Click" FullWidth="true" Class="d-flex justify-content-center align-items-center">
                                <span class="fw-bold text-primary">Cierre Manual</span>
                            </MudButton>

                            <MudCollapse Expanded="_expandCloseLoad">
                                <div class="d-flex justify-content-center mt-2">
                                    <MudRadioGroup @bind-Value="isCloseMode">
                                        <MudRadio Value="false" Color="Color.Secondary" Dense="false">Normal</MudRadio>
                                        <MudRadio Value="true" Color="Color.Primary" Dense="true">Forzado</MudRadio>
                                    </MudRadioGroup>
                                </div>

                                @if (!isCloseMode)
                                {
                                    <div class="modal-footer modal-blue-footer d-flex justify-content-end mt-2">
                                        <button class="btn btn-outline-primary btn-sm"
                                                @onclick="GetNetVolAutoAsync"
                                                disabled="@isCalculatingNet">
                                            @if (isCalculatingNet)
                                            {
                                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                                <span>Calculando...</span>
                                            }
                                            else
                                            {
                                                <span>Calcular Volumen</span>
                                            }
                                        </button>
                                    </div>

                                    <div class="row g-2 mb-2">
                                        <div class="col-6">
                                            <label class="form-label fw-bold">V.Bruto(GROSS)</label>
                                            <input class="form-control input-blue" type="number" @bind="inputGross" />
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label fw-bold">Precio(Temperatura)</label>
                                            <input class="form-control input-blue" type="number" @bind="inputTemperature" />
                                        </div>
                                        <div class="col-12 mb-2">
                                            <label class="form-label fw-bold">Monto(V.Neto)</label>
                                            <input class="form-control input-blue" type="number" @bind="inputNet" />
                                        </div>
                                    </div>

                                    <div class="modal-footer modal-blue-footer d-flex justify-content-between">
                                        <button class="btn btn-outline-info" @onclick="() => CloseModalAsync(true)">Cerrar</button>
                                        <button class="btn btn-success" @onclick="SaveModalAsync" disabled="@isSavingModal">
                                            @(isSavingModal ? "Guardando..." : "Guardar")
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <div class="modal-footer modal-blue-footer d-flex justify-content-between">
                                        <button class="btn btn-danger col-12 col-md-12 mb-3" @onclick="SaveModalAsync" disabled="@isSavingModal">
                                            @(isSavingModal ? "Forzando cierre..." : "Forzar")
                                        </button>
                                    </div>
                                }
                            </MudCollapse>
                        </MudPaper>
                    </MudStack>
                </div>
            </div>
        </div>
    </div>
}

@if (showTransactionModal)
{
    <div class="modal-backdrop-custom" @onclick="() => CloseModalAsync(false)"></div>

    <div class="modal d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">
            <div class="modal-content modal-blue">
                <div class="modal-header modal-blue-header">
                    <h5 class="modal-title">Detalle Transaccion</h5>
                    <button type="button" class="btn-close" @onclick="() => CloseModalAsync(false)"></button>
                </div>

                <div class="modal-body">
                    <div class="col-12 col-md-12 text-center mb-2">
                        <label class="form-label fw-bold text-primary"># Transacción</label>
                        <input class="form-control text-center fw-bold fs-4 input-blue-readonly"
                               value="@(Transaction?.TransactionId.ToString() ?? "")"
                               readonly />
                    </div>

                    <div class="col-12 col-md-12 text-center mb-2">
                        <label class="form-label fw-bold text-primary"># Secuencia</label>
                        <input class="form-control text-center fw-bold fs-4 input-blue-readonly"
                               value="@(Transaction?.id.ToString() ?? "")"
                               readonly />
                    </div>

                    <div class="section-separator">
                        <span>Correcciones</span>
                    </div>

                    <div class="row g-2 mb-2">
                        <div class="col-6">
                            <label class="form-label fw-bold">Volumen(Bruto/GROSS)</label>
                            <input class="form-control input-blue" type="number" @bind="inputGross" />
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-bold">Precio(Temperatura)</label>
                            <input class="form-control input-blue" type="number" @bind="inputTemperature" />
                        </div>
                        <div class="col-6 mb-2">
                            <label class="form-label fw-bold">Monto(V.Neto)</label>
                            <input class="form-control input-blue" type="number" @bind="inputNet" />
                        </div>
                        <div class="col-6 mb-2">
                            <label class="form-label fw-bold">Totalizador</label>
                            <input class="form-control input-blue" type="number" @bind="inputTotalizadorFinal" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer modal-blue-footer">
                    <button class="btn btn-outline-primary" @onclick="() => CloseModalAsync(false)">Cerrar</button>
                    <button class="btn btn-success" @onclick="SaveModalAsync" disabled="@isSavingModal">
                        @(isSavingModal ? "Guardando..." : "Guardar")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private CancellationTokenSource? _connectCts;

    private bool isCalculatingNet;

    private decimal? inputGross;
    private decimal? inputNet;
    private decimal? inputTemperature;
    private decimal? inputTotalizadorFinal;

    private List<ConnItem> connections = new();
    private string selectedName = "";

    private bool isBusy;
    private bool isConnected;

    private bool isLoadingDispensaries;
    private string? dispensariesError;

    private List<DispensaryDto> dispensaries = new();
    private int? selectedDispensaryId;

    private bool isLoadingTables;
    private string? tablesError;

    private List<TransactionDto> transactions = new();
    private List<BinnacleDto> binnacle = new();

    private static string Format2(double? v) => v.HasValue ? v.Value.ToString("N2") : "-";

    private bool isCloseManual;
    private bool isUpdateTrans;
    private bool isSavingModal;

    private bool showBinnacleModal;
    private BinnacleDto? selectedBinnacle;

    private bool showTransactionModal;
    private TransactionDto? Transaction;

    private bool CanConnect => !string.IsNullOrWhiteSpace(selectedName);

    private bool isCloseMode = false;
    private bool _expandBinnacle = false;
    private bool _expandCloseLoad = true;
    private bool _expandSequence = false;
    private DateTime selectedDay = DateTime.Today;

    // ===== NUEVO: selector de día =====
    private string selectedDayText = DateTime.Today.ToString("yyyy-MM-dd");
    private DateTime SelectedDay => DateTime.ParseExact(selectedDayText, "yyyy-MM-dd", CultureInfo.InvariantCulture);

    protected override Task OnInitializedAsync()
    {
        connections = ConnectionSelector.GetConnections().ToList();
        selectedName = ConnState.GetSelectedName() ?? "";
        isConnected = false;
        return Task.CompletedTask;
    }

    private void OnExpandCollapseClick() => _expandBinnacle = !_expandBinnacle;
    private void OnExpandCollapse2Click() => _expandCloseLoad = !_expandCloseLoad;
    private void OnExpandCollapse3Click() => _expandSequence = !_expandSequence;

    private async Task ReloadByDayAsync()
    {
        await LoadAsync();
    }

    private async Task ConnectAsync()
    {
        if (!CanConnect || isConnected) return;

        isBusy = true;
        dispensariesError = null;

        dispensaries.Clear();
        selectedDispensaryId = null;
        transactions.Clear();
        binnacle.Clear();

        _connectCts?.Cancel();
        _connectCts?.Dispose();
        _connectCts = new CancellationTokenSource(TimeSpan.FromSeconds(30));
        var ct = _connectCts.Token;

        try
        {
            ConnState.SetSelectedName(selectedName);

            var result = await CloseLoadApi.GetDbInfoAsync(selectedName, ct);

            if (result is null || !result.Success)
            {
                ToastService.ShowError(result?.Message ?? "No se recibió información de conexión.");
                return;
            }

            await LoadDispensariesAsync();

            isConnected = true;

            await FileLogger.InfoAsync($"Conectado a {selectedName}");
            ToastService.ShowSuccess(result.Message ?? "Conexión exitosa");
        }
        catch (OperationCanceledException)
        {
            await FileLogger.ErrorAsync("ConnectAsync => Timeout (30s)");
            ToastService.ShowError("La conexión tardó más de 30 segundos, se canceló. Intente nuevamente.", "Tiempo de espera");
        }
        catch (Exception ex)
        {
            isConnected = false;
            await FileLogger.ErrorAsync("ConnectAsync => " + ex);
            ToastService.ShowError(ex.Message, "Error al establecer conexión");
        }
        finally
        {
            isBusy = false;
            StateHasChanged();
        }
    }

    private async Task LoadDispensariesAsync()
    {
        isLoadingDispensaries = true;
        dispensariesError = null;

        try
        {
            var station = selectedName;

            if (string.IsNullOrWhiteSpace(station))
            {
                dispensariesError = "Seleccione una estación.";
                dispensaries.Clear();
                return;
            }

            var list = await CloseLoadApi.GetDispensariosAsync(station);
            dispensaries = list.ToList();
        }
        catch (Exception ex)
        {
            dispensariesError = ex.Message;
            await FileLogger.ErrorAsync("LoadDispensariesAsync => " + ex);
            ToastService.ShowError(ex.Message, "Error al obtener los dispensarios");
        }
        finally
        {
            isLoadingDispensaries = false;
            StateHasChanged();
        }
    }

    private void Disconnect()
    {
        _connectCts?.Cancel();
        _connectCts?.Dispose();
        _connectCts = null;

        isConnected = false;
        isBusy = false;

        dispensaries.Clear();
        selectedDispensaryId = null;
        dispensariesError = null;

        transactions.Clear();
        binnacle.Clear();
        tablesError = null;

        ConnState.SetSelectedName("");
        selectedName = "";

        StateHasChanged();
    }

    private async Task OnDispensaryChangedAsync(ChangeEventArgs e)
    {
        if (e?.Value is null || string.IsNullOrWhiteSpace(e.Value.ToString()))
        {
            selectedDispensaryId = null;
            transactions.Clear();
            binnacle.Clear();
            return;
        }

        selectedDispensaryId = int.Parse(e.Value.ToString()!);
        await LoadAsync();
    }

    private async Task OpenTransactionModal(TransactionDto row)
    {
        isCloseManual = false;
        isUpdateTrans = true;
        showTransactionModal = true;
        Transaction = row;

        inputGross = (decimal)(Transaction.Volume ?? 0d);
        inputNet = (decimal)(Transaction.Amount ?? 0d);
        inputTemperature = (decimal)(Transaction.UnitPrice ?? 0d);
        inputTotalizadorFinal = ParseDecimalOrZero(Transaction.strTotalizadorFinal);

        StateHasChanged();
        await Task.CompletedTask;
    }

    private static decimal ParseDecimalOrZero(string? s)
    {
        if (string.IsNullOrWhiteSpace(s))
            return 0m;

        var normalized = s.Trim().Replace(",", ".");
        return decimal.TryParse(normalized, NumberStyles.Any, CultureInfo.InvariantCulture, out var v) ? v : 0m;
    }

    private async Task OpenBinnacleModalAsync(BinnacleDto row)
    {
        isCloseManual = true;
        isUpdateTrans = false;

        selectedBinnacle = row;

        inputGross = null;
        inputNet = null;
        inputTemperature = null;

        showBinnacleModal = true;
        StateHasChanged();
        await Task.CompletedTask;
    }

    private async Task CloseModalAsync(bool isBinnacle)
    {
        if (isBinnacle)
        {
            showBinnacleModal = false;
            selectedBinnacle = null;
        }
        else
        {
            showTransactionModal = false;
            Transaction = null;
        }

        await LoadAsync();
    }

    private async Task SaveModalAsync()
    {
        isSavingModal = true;

        await FileLogger.InfoAsync("SaveModalAsync | Start | " +
                                  $"inputGross={inputGross} inputNet={inputNet} inputTemperature={inputTemperature}");

        try
        {
            if (!isCloseMode) // Normal
            {
                if (inputGross <= 0 || inputNet <= 0 || inputTemperature == 0)
                {
                    ToastService.ShowError("Debe capturar Bruto, Neto y Temperatura.");
                    return;
                }

                if (isUpdateTrans)
                {
                    var dto = new TransactionUpdateDto
                    {
                        Station = selectedName,
                        TransactionId = Transaction!.TransactionId,
                        UnitPrice = (double)inputTemperature!,
                        Volume = (double)inputGross!,
                        Amount = (double)inputNet!,
                        strTotalizadorFinal = inputTotalizadorFinal?.ToString(CultureInfo.InvariantCulture)
                    };

                    var resp = await CloseLoadApi.UpdateTransactionBySequenceAsync(dto);

                    if (!resp.Success)
                    {
                        ToastService.ShowError(resp.Message ?? "No se pudo actualizar la transacción.");
                        return;
                    }

                    ToastService.ShowSuccess(resp.Message ?? "Transacción actualizada.");
                    return;
                }

                if (isCloseManual)
                {
                    await CloseLoadApi.CloseManualAsync(
                        station: selectedName,
                        secuenciaBuscar: selectedBinnacle!.id,
                        volumenGross: inputGross ?? 0m,
                        volumenNetoCt: inputNet ?? 0m,
                        temperatura: inputTemperature ?? 0m);

                    ToastService.ShowSuccess("La carga fue cerrada correctamente.");
                }
            }
            else
            {
                var resp = await CloseLoadApi.CloseForcedAsync(station: selectedName, idSec: selectedBinnacle!.id);

                if (!resp.Success)
                {
                    ToastService.ShowError(resp.Message ?? "No se pudo forzar el cierre.");
                    return;
                }

                ToastService.ShowSuccess(resp.Message ?? "Cierre forzado ejecutado correctamente.");
            }
        }
        catch (Exception ex)
        {
            await FileLogger.ErrorAsync("SaveModalAsync | End(Err) " + ex);
            ToastService.ShowError(ex.Message, "Error");
        }
        finally
        {
            isSavingModal = false;
            StateHasChanged();
        }
    }

    private async Task GetNetVolAutoAsync()
    {
        if (inputGross <= 0 || inputTemperature <= 0)
        {
            ToastService.ShowError("Capture un Volumen Bruto (GROSS) o temperatura válida (> 0).");
            return;
        }

        if (selectedBinnacle is null)
        {
            ToastService.ShowError("No hay secuencia seleccionada.");
            return;
        }

        var disp = selectedBinnacle.DispensaryId ?? 0;
        var prod = selectedBinnacle.ProductId ?? 0;

        if (isCalculatingNet) return;

        try
        {
            isCalculatingNet = true;
            StateHasChanged();

            var volNetoAuto = await CloseLoadApi.GetNetVolAutoAsync(
                station: selectedName,
                intDispensario: disp,
                intProducto: prod,
                temperatura: inputTemperature ?? 0m,
                volumenGross: inputGross ?? 0m);

            inputNet = volNetoAuto;

            ToastService.ShowSuccess("Se obtuvo el volumen neto automáticamente");
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message, "No se pudo calcular el volumen neto, colóquelo manual");
            await FileLogger.ErrorAsync("GetNetVolAutoAsync => " + ex);
        }
        finally
        {
            isCalculatingNet = false;
            StateHasChanged();
        }
    }

    private async Task ExportLog()
    {
        await FileLogger.ExportToDownloadsAsync();
        ToastService.ShowSuccess("Log copiado a Descargas");
    }

    private async Task LoadAsync()
    {
        if (!selectedDispensaryId.HasValue) return;

        isLoadingTables = true;
        tablesError = null;
        transactions.Clear();
        binnacle.Clear();
        StateHasChanged();

        try
        {
            var dispId = selectedDispensaryId.Value;

            // BITÁCORA por DÍA (Top 20)
            var bTask = CloseLoadApi.GetBinnacleTopByDayAsync(selectedName, dispId, selectedDay);

            // Transacciones como ya lo tenías
            var tTask = CloseLoadApi.GetTransactionsTopAsync(selectedName, dispId);

            await Task.WhenAll(bTask, tTask);

            binnacle = (await bTask).ToList();
            transactions = (await tTask).ToList();

            if (!binnacle.Any() && !transactions.Any())
                ToastService.ShowInfo("No se encontraron registros.");
        }
        catch (Exception ex)
        {
            await FileLogger.ErrorAsync("ReloadTablesAsync => " + ex);
            ToastService.ShowError("Error al refrescar la bitácora y/o transacciones");
        }
        finally
        {
            isLoadingTables = false;
            StateHasChanged();
        }
    }
}
