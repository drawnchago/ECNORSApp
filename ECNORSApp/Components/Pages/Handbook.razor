@page "/handbook"
@using ECNORSApp.Data.DTO
@using Microsoft.AspNetCore.Components.Forms
@using ECNORSApp.Services
@inject HandbookApi HandbookApi
@inject ECNORSApp.Services.IToastService ToastService
@inject ECNORSApp.Services.IFileLoggerService FileLogger

<h4>📘 Base de conocimiento</h4>

<div class="table-card">
    <div class="table-toolbar">
        <div class="fw-semibold">Documentación</div>

        <div class="d-flex gap-2 align-items-center flex-wrap">
            <input class="form-control form-control-sm"
                   style="min-width:260px"
                   placeholder="Buscar (nombre o carpeta)..."
                   @bind="search"
                   @bind:event="oninput"
                   disabled="@isBusy" />

            <button class="btn btn-primary btn-sm" @onclick="Load" disabled="@isBusy">Refrescar 🔄</button>

            <button class="btn btn-success btn-sm" @onclick="OpenUploadModal" disabled="@isBusy" title="Subir archivo">
                <span class="fw-bold">Agregar +</span>
            </button>
        </div>
    </div>

    <div class="table-responsive table-responsive-modern">
        <table class="table table-hover align-middle mb-0 table-modern">
            <thead>
                <tr>
                    <th class="text-nowrap">Nombre</th>
                    <th class="text-nowrap text-end">Acciones</th>
                </tr>
            </thead>

            <tbody>
                @if (FilteredFiles.Count == 0)
                {
                    <tr>
                        <td colspan="2" class="text-muted py-4 text-center">
                            No hay archivos que coincidan con el filtro.
                        </td>
                    </tr>
                }
                else
                {
                    var grouped = FilteredFiles
                    .OrderBy(f => GetFolder(f.RelativePath))
                    .ThenBy(f => f.OriginalName)
                    .GroupBy(f => GetFolder(f.RelativePath))
                    .ToList();

                    @foreach (var group in grouped)
                    {
                        <!-- Header de carpeta ocupa TODA la fila (Nombre + Acciones) -->
                        <tr class="folder-row folder-click" @onclick="() => ToggleFolder(group.Key)" style="cursor:pointer;">
                            <td colspan="2" class="fw-bold">
                                <div class="d-flex align-items-center gap-2">
                                    <span>@(IsOpen(group.Key) ? "📂" : "📁")</span>
                                    <span>@group.Key</span>

                                    <span class="ms-auto text-muted small">
                                        @(IsOpen(group.Key) ? "Ocultar" : "Mostrar") (@group.Count())
                                    </span>
                                </div>
                            </td>
                        </tr>

                        @if (IsOpen(group.Key))
                        {
                            @foreach (var f in group)
                            {
                                <tr>
                                    <td class="text-nowrap">
                                        <span title="@f.OriginalName">@f.OriginalName</span>
                                    </td>

                                    <td class="text-end d-flex gap-2 justify-content-end">
                                        <button class="btn btn-outline-secondary btn-sm"
                                                @onclick:stopPropagation="true"
                                                @onclick="() => ViewPdf(f.Id)"
                                                disabled="@isBusy"
                                                title="Ver">
                                            👁
                                        </button>

                                        <button class="btn btn-outline-primary btn-sm"
                                                @onclick:stopPropagation="true"
                                                @onclick="() => Download(f.Id)"
                                                disabled="@isBusy"
                                                title="Descargar">
                                            ⬇
                                        </button>

                                        <button class="btn btn-outline-danger btn-sm"
                                                @onclick:stopPropagation="true"
                                                @onclick="() => DeleteFile(f.Id)"
                                                disabled="@isBusy"
                                                title="Eliminar">
                                            🗑
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@if (showUploadModal)
{
    <div class="modal-backdrop fade show"></div>

    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Subir archivo(s)</h5>
                    <button type="button" class="btn-close" @onclick="CloseUploadModal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <div class="row g-3 align-items-end">
                        <div class="col-12">
                            <label class="form-label fw-bold">Carpeta destino</label>
                            <input class="form-control" placeholder="Ej: Manuales, Imagenes, PDF" @bind="folder" />
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-bold">Archivos (PDF)</label>

                            <div class="d-flex align-items-center gap-3 flex-wrap">
                                <label class="col-12 btn btn-outline-primary d-flex align-items-center gap-2 mb-0">
                                    <span>📁</span>
                                    <span>@FilesSelectedText</span>
                                    <InputFile OnChange="OnFilesSelected" multiple accept=".pdf,application/pdf" hidden />
                                </label>
                            </div>

                            @if (_files.Count > 0)
                            {
                                <div class="mt-2 small text-muted">
                                    @foreach (var f in _files.Take(6))
                                    {
                                        <div>• @f.Name</div>
                                    }
                                    @if (_files.Count > 6)
                                    {
                                        <div>… y @(_files.Count - 6) más</div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="CloseUploadModal" disabled="@isBusy">
                        Cancelar
                    </button>

                    <button class="btn btn-success" @onclick="UploadFromModal" disabled="@(_files.Count == 0 || isBusy)">
                        @if (isBusy)
                        {
                            <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
                            <span class="ms-2">Guardando...</span>
                        }
                        else
                        {
                            <span>Subir archivo(s)</span>
                        }
                    </button>
                </div>

            </div>
        </div>
    </div>
}

<style>
    .folder-row td {
        background: #f5f7fa;
        border-top: 2px solid #dee2e6;
    }

    .folder-click:hover td {
        background: #eef3ff;
    }
</style>

@code {
    public bool isBusy = false;

    private string? folder = "Manual";

    // filtro
    private string search = "";

    private List<HandbookDto> files = new();

    // multi archivo
    private List<IBrowserFile> _files = new();
    private string FilesSelectedText =>
        _files.Count == 0 ? "Seleccionar archivos" :
        _files.Count == 1 ? _files[0].Name :
        $"{_files.Count} archivos seleccionados";

    private bool showUploadModal;

    // accordion: iniciar compacto (todo cerrado)
    private HashSet<string> _openFolders = new(StringComparer.OrdinalIgnoreCase);

    private IReadOnlyList<HandbookDto> FilteredFiles
    {
        get
        {
            if (string.IsNullOrWhiteSpace(search))
                return files;

            var s = search.Trim();

            return files.Where(f =>
            {
                var name = f.OriginalName ?? "";
                var folderName = GetFolder(f.RelativePath);
                return name.Contains(s, StringComparison.OrdinalIgnoreCase)
                       || folderName.Contains(s, StringComparison.OrdinalIgnoreCase);
            }).ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await Load();
        // Compactado al cargar: no abrimos nada por defecto
        _openFolders.Clear();
    }

    private async Task Load()
    {
        try
        {
            files = (await HandbookApi.GetAsync()).ToList();

            if (files.Count == 0)
                ToastService.ShowInfo("No hay archivos cargados.");

            // mantener compacto al recargar:
            // no abrimos carpetas automáticamente
        }
        catch (Exception ex)
        {
            await FileLogger.ErrorAsync($"❌ Error al cargar=> {ex.Message}");
            ToastService.ShowError("❌ Error al cargar");
        }
    }

    // Toggle normal (varias abiertas)
    private void ToggleFolder(string folderName)
    {
        if (_openFolders.Contains(folderName))
            _openFolders.Remove(folderName);
        else
            _openFolders.Add(folderName);
    }

    private bool IsOpen(string folderName) => _openFolders.Contains(folderName);

    private void OpenUploadModal()
    {
        showUploadModal = true;
    }

    private void CloseUploadModal()
    {
        showUploadModal = false;
        _files.Clear();
    }

    private void OnFilesSelected(InputFileChangeEventArgs e)
    {
        _files.Clear();

        // Aceptar hasta 26 archivos
        foreach (var file in e.GetMultipleFiles(26))
        {
            var isPdf = string.Equals(file.ContentType, "application/pdf", StringComparison.OrdinalIgnoreCase);
            var hasPdfExt = Path.GetExtension(file.Name).Equals(".pdf", StringComparison.OrdinalIgnoreCase);

            if (!isPdf && !hasPdfExt)
            {
                ToastService.ShowError($"Solo PDF: {file.Name}");
                _ = FileLogger.ErrorAsync($"Archivo rechazado (no PDF) | Name={file.Name} | Type={file.ContentType}");
                continue;
            }

            _files.Add(file);
        }

        if (_files.Count > 0)
        {
            _ = FileLogger.InfoAsync($"PDFs seleccionados: {_files.Count}");
            ToastService.ShowInfo($"{_files.Count} PDF(s) seleccionado(s).");
        }
    }

    private async Task Upload()
    {
        if (_files.Count == 0 || string.IsNullOrWhiteSpace(folder))
        {
            ToastService.ShowError("Selecciona carpeta y al menos un archivo.");
            return;
        }

        isBusy = true;

        try
        {
            await FileLogger.InfoAsync($"⏳ Subiendo {_files.Count} archivo(s)... Folder:{folder}");

            foreach (var f in _files)
            {
                await using var stream = f.OpenReadStream(50_000_000);
                await HandbookApi.UploadAsync(stream, f.Name, f.ContentType, folder);
                await FileLogger.InfoAsync($"✅ Subido: {f.Name}");
            }

            ToastService.ShowSuccess("✅ Archivos cargados correctamente.");
            _files.Clear();

            await Load();
        }
        catch (Exception ex)
        {
            await FileLogger.ErrorAsync($"❌ Error al subir: {ex.Message}");
            ToastService.ShowError("❌ Error al subir, intente nuevamente");
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task UploadFromModal()
    {
        await Upload();
        if (!isBusy) showUploadModal = false;
    }

    private async Task Download(long id)
    {
        try
        {
            isBusy = true;
            await FileLogger.InfoAsync($"Descargando...| id:{id}");
            ToastService.ShowInfo("Descargando..");

            var bytes = await HandbookApi.DownloadAsync(id);

            var path = Path.Combine(FileSystem.AppDataDirectory, $"handbook_{id}");
            await File.WriteAllBytesAsync(path, bytes);

            await FileLogger.InfoAsync($"✅ Descargado | id:{id}");
            ToastService.ShowSuccess($"✅ Guardado en: {path}");
        }
        catch (Exception ex)
        {
            await FileLogger.ErrorAsync("❌ Error al descargar: " + ex.Message);
            ToastService.ShowError("❌ Error al descargar");
        }
        finally
        {
            isBusy = false;
            _ = Load();
        }
    }

    private async Task ViewPdf(long id)
    {
        try
        {
            isBusy = true;
            var uri = HandbookApi.GetViewPdfUri(id);
            await Launcher.Default.OpenAsync(uri);
        }
        catch (Exception ex)
        {
            await FileLogger.ErrorAsync("❌ Error al visualizar: " + ex.Message);
            ToastService.ShowError("No se pudo abrir el documento");
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task DeleteFile(long id)
    {
        if (isBusy) return;

        try
        {
            isBusy = true;

            var response = await HandbookApi.DeleteAsync(id);

            if (response.succes)
            {
                files.RemoveAll(x => x.Id == id);
                ToastService.ShowSuccess(response.message ?? "Eliminado");
            }
            else
            {
                ToastService.ShowError(response.message ?? "Error al eliminar");
            }
        }
        finally
        {
            isBusy = false;
            _ = Load();
        }
    }

    private static string GetFolder(string? relativePath)
    {
        if (string.IsNullOrWhiteSpace(relativePath))
            return "Sin carpeta";

        var parts = relativePath.Split(new[] { '/', '\\' }, StringSplitOptions.RemoveEmptyEntries);

        var storageIndex = Array.FindIndex(parts,
            p => p.Equals("Storage", StringComparison.OrdinalIgnoreCase));

        if (storageIndex >= 0 && storageIndex + 1 < parts.Length)
            return parts[storageIndex + 1];

        return "Sin carpeta";
    }
}
